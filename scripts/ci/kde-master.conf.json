{
    "description": "Testing distribution configurations for KDE Yocto Layers",
    "sources": {
        "bitbake": {
            "git-remote": {
                "uri": "https://github.com/openembedded/bitbake.git",
                "branch": "master",
                "rev": "yocto-6.0"
            }
        },
        "openembedded-core": {
            "git-remote": {
                "uri": "https://github.com/openembedded/openembedded-core.git",
                "branch": "wrynose",
                "rev": "yocto-6.0"
            }
        },
        "meta-yocto": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "https://git.yoctoproject.org/meta-yocto"
                    }
                },
                "branch": "master",
                "rev": "yocto-6.0"
            }
        },
        "meta-openembedded": {
            "git-remote": {
                "uri": "https://github.com/openembedded/meta-openembedded.git",
                "branch": "wrynose",
                "rev": "05191ba25b6dcf15a28dac2231bd0d2f9ab514da"
            }
        },
        "meta-riscv": {
            "git-remote": {
                "uri": "https://github.com/riscv/meta-riscv",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-qt6": {
            "git-remote": {
                "uri": "https://code.qt.io/yocto/meta-qt6",
                "branch": "6.11",
                "rev": "6.11"
            }
        },
        "meta-kf6": {
            "git-remote": {
                "uri": "https://invent.kde.org/packaging/yocto-meta-kf6",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-kde": {
            "git-remote": {
                "uri": "https://invent.kde.org/packaging/yocto-meta-kde",
                "branch": "master",
                "rev": "master"
            }
        }
    },
    "bitbake-setup": {
        "configurations": [
        {
            "bb-layers": [
                "meta-kde",
                "meta-kf6",
                "meta-openembedded/meta-multimedia",
                "meta-openembedded/meta-networking",
                "meta-openembedded/meta-oe",
                "meta-openembedded/meta-perl",
                "meta-openembedded/meta-python",
                "meta-qt6",
                "meta-riscv",
                "meta-yocto/meta-poky",
                "meta-yocto/meta-yocto-bsp",
                "openembedded-core/meta"
            ],
            "setup-dir-name": "$distro-master",
            "oe-fragments-one-of": {
                "machine": {
                    "description": "Target machines",
                    "options" : [
                        { "name": "machine/qemux86-64", "description": "x86-64 system on QEMU" },
                        { "name": "machine/qemuarm64", "description": "ARMv8 system on QEMU" },
                        { "name": "machine/qemuriscv64", "description": "RISC-V system on QEMU" },
                        { "name": "machine/beaglev-ahead", "description": "Beagle-V Ahead" }
                    ]
                },
                "distro": {
                    "description": "Target distributions",
                    "options" : [
                        { "name": "distro/poky", "description": "Yocto Project Reference Distro" }
                    ]
                }
            },
            "configurations": [
                {
                    "name": "kde",
                    "description": "KDE - Test"
                }
            ]
        }
        ]
    },
    "version": "1.0"
}
